DATABASE_URL="postgresql://postgres:postgres@localhost:5432/legacy_vault"
NEXTAUTH_SECRET="change-me-in-production-min-32-chars-long"
NEXTAUTH_URL="http://localhost:3000"

# Private IPFS node (set to real values in production; now CF/Troptions IPFS for Web3)
IPFS_API_URL="http://localhost:5001" # or CF IPFS gateway
IPFS_GATEWAY_URL="http://localhost:8080" # or https://<cid>.ipfs.cf-ipfs.com
IPFS_AUTH_TOKEN=""

# Troptions Rails primary for Legacy: Besu (compliance/estate) + XRPL (settlement)
# Use from troptions-rails or testnets; master bootstrap for full system
BESU_RPC="https://your-besu-or-troptions-besu" # primary for LegacyVaultRegistry etc.
XRPL_ENDPOINT="s.altnet.rippletest.net" # for payouts/settlement
AVALANCHE_RPC="https://api.avax-test.network/ext/bc/C/rpc" # for RWA/VRF test (Fuji)

# Legacy originals
CHAIN_RPC_URL="$BESU_RPC" # updated to Besu/Troptions
CHAIN_CONTRACT_ADDRESS="0x0000000000000000000000000000000000000000"
CHAIN_ADMIN_KEY=""

# Encryption master key (32-byte hex, must be set in production)
VAULT_MASTER_KEY=""

# Feature flags (set false for real rails in prod)
MOCK_IPFS=true
MOCK_CHAIN=true

# BBS+ selective disclosure (GemAssetCredential proofType: "bbs")
# Set MOCK_BBS=true in CI for placeholder proofs without real signing.
MOCK_BBS=false
# Base64-encoded BLS12-381 key pair from @digitalbazaar/bbs-signatures generateKeyPair.
# If unset, ephemeral keys are generated per process (dev only).
BBS_SECRET_KEY_HEX=
BBS_PUBLIC_KEY_HEX=

# SD-JWT gem issuance mock (proofType: "sd-jwt" only)
GEM_VC_ISSUANCE_MOCK=false

# Vercel / Prisma engine (must be set in Vercel environment variables)
PRISMA_CLIENT_ENGINE_TYPE=library

# Troptions Rails / Web3 (from cloudflare api.txt - use as secret!)
CLOUDFLARE_API_TOKEN=cfut_YOUR_TOKEN_HERE # verified active; for Pages/IPFS/Workers/gateways
CLOUDFLARE_IPFS_GATEWAY=https://<your>.ipfs.cf-ipfs.com
# Master deploy (troptions-rails/scripts + Legacy on Besu): ./scripts/deploy-all.sh
# Full system: Legacy (Besu) + 33 Troptions contracts, wired via BridgePayload/SystemValidator
